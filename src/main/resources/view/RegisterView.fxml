<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.RegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="ĐĂNG KÝ TÀI KHOẢN">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="5.0">
        <Label text="Tên đăng nhập:" />
        <TextField fx:id="regUsernameField" promptText="Nhập username..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Mật khẩu:" />
        <PasswordField fx:id="regPasswordField" promptText="Nhập mật khẩu..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Xác nhận mật khẩu:" />
        <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Bạn là:" />
        <ComboBox fx:id="roleComboBox" prefWidth="200.0" promptText="-- Chọn vai trò --">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Bidder (Người mua)" />
                    <String fx:value="Seller (Người bán)" />
                </FXCollections>
            </items>
        </ComboBox>
    </VBox>

    <Label fx:id="regErrorLabel" textFill="#144680"/>

    <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" prefWidth="200.0" text="ĐĂNG KÝ" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-weight: bold;" />

    <Hyperlink fx:id="loginLink" onAction="#goToLogin" text="Đã có tài khoản? Quay lại đăng nhập" />
</VBox>