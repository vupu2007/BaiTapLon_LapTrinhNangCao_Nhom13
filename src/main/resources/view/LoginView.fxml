<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="HỆ THỐNG ĐẤU GIÁ">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Đăng nhập để tiếp tục" textFill="#666666" />

    <VBox spacing="5.0">
        <Label text="Tên đăng nhập:" />
        <TextField fx:id="usernameField" promptText="Nhập username..." />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Mật khẩu:" />
        <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu..." />
    </VBox>

    <Label fx:id="errorLabel" textFill="RED" />

    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefWidth="200.0" text="ĐĂNG NHẬP" style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-weight: bold;" />

    <Hyperlink fx:id="registerLink" onAction="#goToRegister" text="Chưa có tài khoản? Đăng ký ngay" />
</VBox>